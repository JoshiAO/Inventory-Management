rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is superuser
    function isSuperuser() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superuser';
    }

    // User profiles
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read, update: if request.auth != null && (request.auth.uid == userId || isSuperuser());
      allow delete: if isSuperuser();
    }

    // Facilities management (Superuser only)
    match /facilities/{facilityId} {
      allow read: if request.auth != null;
      allow write: if isSuperuser();
    }

    // Inventory items (Global - Read all, Superuser write)
    match /items/{itemId} {
      allow read: if request.auth != null;
      allow write: if isSuperuser();
    }
    
    // Categories (Global - Read all, Superuser write)
    match /categories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if isSuperuser();
    }

    // Prices (Nested Facility Structure)
    match /prices/{facilityId} {
      allow read: if request.auth != null;
      match /records/{recordId} {
        allow read: if request.auth != null;
        allow write: if isSuperuser();
      }
    }

    // SSR Baseline (Nested Facility Structure)
    match /ssr_baseline/{facilityId} {
      allow read: if request.auth != null;
      match /records/{recordId} {
        allow read: if request.auth != null;
        allow write: if isSuperuser();
      }
    }

    // Count records (Nested Facility Structure)
    match /counts/{facilityId} {
      allow read: if request.auth != null;
      match /records/{recordId} {
        allow create: if request.auth != null;
        allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isSuperuser());
        allow update, delete: if isSuperuser();
      }
    }
  }
}
